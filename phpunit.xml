<?xml version="1.0" encoding="UTF-8"?>
<!-- cacheResult off: in the Docker dev stack PHPUnit runs as www-data inside a
     bind mount owned by the host user, so writing .phpunit.result.cache fails
     and spams the server log with permission warnings. -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.6/phpunit.xsd" bootstrap="tests/bootstrap.php" colors="true" cacheResult="false">
	<testsuites>
		<testsuite name="unit">
			<directory>tests/Unit</directory>
		</testsuite>
		<testsuite name="integration">
			<directory>tests/Integration</directory>
		</testsuite>
	</testsuites>
</phpunit>
